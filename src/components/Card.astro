---
// src/components/Card.astro (示例)

const { link } = Astro.props;
const { name, url, icon, description, category } = link;
---

<!-- 原有的卡片结构 -->
<!-- <div class="card"> ... </div> -->

<!-- 改造后的资源列表项结构 -->
<div class="resource-item">
  <div class="resource-info">
    <!-- 如果有图标就显示 -->
    {icon && <img src={icon} alt={name} class="resource-icon" />}
    <div>
      <a href={url} class="resource-title">{name}</a>
      <p class="resource-desc">{description}</p>
    </div>
  </div>
  <span class="resource-category">{category}</span>
</div>

<style>
  /* 在这里编写你希望的样式，比如参考 365ym 的列表样式 */
  .resource-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #eee;
  }
  /* ... 更多样式 */
</style>
