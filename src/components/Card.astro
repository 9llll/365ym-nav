---
// Card.astro — 365ym 风格导航卡片
const { cover, title, slug, description, category, meta } = Astro.props;
---

<a href={`/post/${slug}/`} class="card group">
  <div class="card-cover">
    {cover ? (
      <img src={cover} alt={title} loading="lazy" />
    ) : (
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:48px;font-weight:700;">
        {title?.charAt(0) || '?'}
      </div>
    )}
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    {description && <p class="card-desc">{description}</p>}
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:auto;">
      {category && <span class="card-badge">{category}</span>}
      {meta && <span class="card-meta">{meta}</span>}
    </div>
  </div>
</a>
