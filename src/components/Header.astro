---
// Header.astro — 365ym 风格导航栏（毛玻璃 + 汉堡菜单 + 搜索 + 主题切换）
import SearchIsland from '../Island/SearchIsland.jsx';
import ThemeIsland from '../Island/ThemeIsland.jsx';
import { categories } from '../data/navLinks.js';
---

<input type="checkbox" id="nav-toggle" class="nav-toggle" />
<!-- 菜单遮罩，点击关闭 -->
<label for="nav-toggle" class="nav-overlay" aria-hidden="true"></label>

<header class="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo">
      <img src="/images/logo.svg" alt="天天源码" width="113" height="36" />
      <span style="font-size:18px;font-weight:700;">天天源码</span>
    </a>

    <!-- 导航链接 -->
    <nav class="site-nav">
      <a href="/" aria-current="page">首页</a>
      {categories.map(cat => (
        <a href={`/category/${cat.id}/`}>{cat.name}</a>
      ))}
    </nav>

    <!-- 操作区 -->
    <div class="header-actions">
      <button id="search-toggle" aria-label="搜索" class="icon-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
      <button id="theme-toggle" onclick="window.toggleTheme && window.toggleTheme()" aria-label="切换主题" class="icon-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="dark-hide">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="dark-show" style="display:none;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <!-- 汉堡按钮 -->
      <label for="nav-toggle" class="nav-btn" aria-label="菜单">
        <span></span>
      </label>
    </div>
  </div>
</header>

<SearchIsland client:idle />
<ThemeIsland client:idle />

<style is:global>
  /* 主题切换图标显隐 */
  html.dark .dark-hide { display: none !important; }
  html.dark .dark-show { display: block !important; }
  html:not(.dark) .dark-hide { display: block !important; }
  html:not(.dark) .dark-show { display: none !important; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 点击导航链接关闭汉堡菜单
    const toggle = document.getElementById('nav-toggle') as HTMLInputElement;
    document.querySelectorAll('.site-nav a').forEach(link => {
      link.addEventListener('click', () => {
        if (toggle) toggle.checked = false;
      });
    });
    // 点击遮罩关闭菜单
    const overlay = document.querySelector('.nav-overlay');
    overlay?.addEventListener('click', () => {
      if (toggle) toggle.checked = false;
    });
  });
</script>
