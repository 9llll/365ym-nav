---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Card from '../components/Card.astro';
import Footer from '../components/Footer.astro';
import { navLinks, categories } from '../data/navLinks.js';

// categoryId → 显示名称映射
const catNameMap = Object.fromEntries(categories.map(c => [c.id, c.name]));

const pageTitle = '天天源码';
const pageDescription = '免费AI工具/源码下载 - 网站源码模板插件分享平台';

// 按发布时间倒序排列
const sortedLinks = [...navLinks].sort((a, b) =>
  new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime()
);

// 首页显示前 12 篇
const perPage = 12;
const displayLinks = sortedLinks.slice(0, perPage);
const hasMore = sortedLinks.length > perPage;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
>
  <Header />

  <!-- Banner 横幅区 -->
  <section class="banner">
    <div class="container banner-inner">
      <div>
        <h1 class="banner-title">天天源码</h1>
        <p class="banner-desc">{pageDescription}</p>
      </div>
      <!-- 搜索表单 -->
      <form class="search-form" onsubmit="return false;">
        <input
          type="text"
          id="banner-search"
          class="search-input"
          placeholder="搜一下你想要的源码或工具..."
          autocomplete="off"
        />
        <button type="button" class="search-btn" id="banner-search-btn">搜索</button>
      </form>
      <!-- 广告位占位 -->
      <div class="banner-slot">广告位</div>
    </div>
  </section>

  <!-- 最新发布 -->
  <section class="section">
    <div class="container">
      <h2 style="font-size:22px;font-weight:700;margin-bottom:16px;color:var(--text);">
        最新发布
      </h2>
      <div class="card-grid">
        {displayLinks.map(link => (
          <Card
            cover={link.cover || ''}
            title={link.title}
            slug={link.slug}
            description={link.description}
            category={catNameMap[link.category] || link.category}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 加载更多 -->
  {hasMore && (
    <div class="container load-more">
      <button class="load-more-btn" id="load-more-btn">
        加载更多
      </button>
    </div>
  )}

  <!-- 友情链接 -->
  <section class="friend-links">
    <div class="container">
      <h3 style="font-size:16px;font-weight:600;margin-bottom:8px;color:var(--text);">友情链接</h3>
      <div class="links">
        <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
        <a href="https://cloudflare.com" target="_blank" rel="noopener">Cloudflare</a>
        <a href="https://github.com" target="_blank" rel="noopener">GitHub</a>
        <a href="https://vercel.com" target="_blank" rel="noopener">Vercel</a>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<script>
  // 搜索功能
  document.addEventListener('DOMContentLoaded', () => {
    const searchBtn = document.getElementById('banner-search-btn');
    const searchInput = document.getElementById('banner-search') as HTMLInputElement;
    const searchToggle = document.getElementById('search-toggle');

    searchBtn?.addEventListener('click', () => {
      searchToggle?.click();
      if (searchInput) {
        setTimeout(() => {
          const modalInput = document.querySelector('#search-toggle + div input') as HTMLInputElement;
          if (modalInput) {
            modalInput.value = searchInput.value;
            modalInput.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }, 200);
      }
    });

    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        searchBtn?.click();
      }
    });
  });
</script>
